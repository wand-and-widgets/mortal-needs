<div class="mn-need-bar mn-need-bar--vertical" data-need-id="{{id}}" data-entity-id="{{entityId}}" data-tooltip="{{localize label}}: {{percentage}}%">
  <span class="mn-need-bar__icon" data-severity="{{severity}}">
    <i class="fas {{icon}}"></i>
  </span>

  <div class="mn-need-bar__track">
    <div class="mn-need-bar__fill"
         data-severity="{{severity}}"
         style="transform: scaleY({{decimal}})">
    </div>
  </div>

  <span class="mn-need-bar__value" data-severity="{{severity}}">{{percentage}}</span>
</div>
