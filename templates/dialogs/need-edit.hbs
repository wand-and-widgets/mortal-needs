<div class="mn-dialog__body">
  <div class="mn-dialog__section">
    <div class="mn-dialog__section-title">{{localize "MORTAL_NEEDS.NeedEdit.General"}}</div>

    {{#if isNew}}
      <div class="mn-dialog__form-group">
        <label>{{localize "MORTAL_NEEDS.NeedEdit.Id"}}</label>
        <input type="text" name="needId" value="{{config.id}}" placeholder="custom-need-id">
      </div>
    {{else}}
      <input type="hidden" name="needId" value="{{config.id}}">
    {{/if}}

    <div class="mn-dialog__form-group">
      <label>{{localize "MORTAL_NEEDS.NeedEdit.Label"}}</label>
      <input type="text" name="label" value="{{config.label}}">
    </div>

    <div class="mn-dialog__form-row">
      <div class="mn-dialog__form-group" style="flex: 1;">
        <label>{{localize "MORTAL_NEEDS.NeedEdit.Icon"}}</label>
        <input type="text" name="icon" value="{{config.icon}}" placeholder="fa-utensils">
      </div>
      <div class="mn-dialog__form-group" style="flex: 1;">
        <label>{{localize "MORTAL_NEEDS.NeedEdit.Category"}}</label>
        <select name="category">
          {{#each categories}}
            <option value="{{this}}" {{#if (eq this ../config.category)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
      </div>
    </div>

    <label class="mn-dialog__checkbox">
      <input type="checkbox" name="enabled" {{#if config.enabled}}checked{{/if}}>
      <span>{{localize "MORTAL_NEEDS.NeedEdit.Enabled"}}</span>
    </label>
  </div>

  <div class="mn-dialog__section">
    <div class="mn-dialog__section-title">{{localize "MORTAL_NEEDS.NeedEdit.Values"}}</div>
    <div class="mn-dialog__form-row">
      <div class="mn-dialog__form-group" style="flex: 1;">
        <label>{{localize "MORTAL_NEEDS.NeedEdit.Min"}}</label>
        <input type="number" name="min" value="{{config.min}}" min="0">
      </div>
      <div class="mn-dialog__form-group" style="flex: 1;">
        <label>{{localize "MORTAL_NEEDS.NeedEdit.Max"}}</label>
        <input type="number" name="max" value="{{config.max}}" min="1">
      </div>
      <div class="mn-dialog__form-group" style="flex: 1;">
        <label>{{localize "MORTAL_NEEDS.NeedEdit.Default"}}</label>
        <input type="number" name="default" value="{{config.default}}" min="0">
      </div>
    </div>
    <div class="mn-dialog__form-group">
      <label>{{localize "MORTAL_NEEDS.NeedEdit.StressAmount"}}</label>
      <input type="number" name="stressAmount" value="{{config.stressAmount}}" min="1" max="100">
    </div>
  </div>

  <div class="mn-dialog__section">
    <div class="mn-dialog__section-title">{{localize "MORTAL_NEEDS.NeedEdit.Decay"}}</div>
    <label class="mn-dialog__checkbox">
      <input type="checkbox" name="decayEnabled" {{#if config.decay.enabled}}checked{{/if}}>
      <span>{{localize "MORTAL_NEEDS.NeedEdit.DecayEnabled"}}</span>
    </label>
    <div class="mn-dialog__form-row">
      <div class="mn-dialog__form-group" style="flex: 1;">
        <label>{{localize "MORTAL_NEEDS.NeedEdit.DecayRate"}}</label>
        <input type="number" name="decayRate" value="{{config.decay.rate}}" min="1">
      </div>
      <div class="mn-dialog__form-group" style="flex: 1;">
        <label>{{localize "MORTAL_NEEDS.NeedEdit.DecayInterval"}} (s)</label>
        <input type="number" name="decayInterval" value="{{config.decay.interval}}" min="60" step="60">
      </div>
    </div>
  </div>

  <div class="mn-dialog__section">
    <div class="mn-dialog__section-title">{{localize "MORTAL_NEEDS.NeedEdit.Consequences"}}</div>
    {{#if config.consequences.length}}
      <div class="mn-dialog__list">
        {{#each config.consequences}}
          <div class="mn-dialog__list-item">
            <span class="mn-text-sm">{{type}}</span>
            <span class="mn-text-xs" style="color: var(--mn-text-muted);">@ {{threshold}}%</span>
          </div>
        {{/each}}
      </div>
    {{else}}
      <p class="mn-text-xs" style="color: var(--mn-text-muted);">{{localize "MORTAL_NEEDS.NeedEdit.NoConsequences"}}</p>
    {{/if}}
    <button class="mn-btn mn-btn--secondary mn-btn--sm" data-action="add-consequence">
      <i class="fas fa-plus"></i>
      <span>{{localize "MORTAL_NEEDS.NeedEdit.AddConsequence"}}</span>
    </button>
  </div>

  <div class="mn-dialog__footer">
    {{#if canDelete}}
      <button class="mn-btn mn-btn--danger mn-btn--sm" data-action="delete-need" style="margin-right: auto;">
        <i class="fas fa-trash"></i>
        <span>{{localize "MORTAL_NEEDS.NeedEdit.Delete"}}</span>
      </button>
    {{/if}}
    <button class="mn-btn mn-btn--primary" data-action="save-need">
      <i class="fas fa-save"></i>
      <span>{{localize "Save"}}</span>
    </button>
  </div>
</div>
